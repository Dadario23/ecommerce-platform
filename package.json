{
  "name": "ecommerce-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:store": "turbo dev --filter=store",
    "dev:admin": "turbo dev --filter=admin-hub",
    "build:store": "turbo build --filter=store",
    "test": "turbo test"
  },
  "devDependencies": {
    "next": "^16.2.10",
    "turbo": "^2.10.4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    },
    "next-auth": {
      "uuid": "^11.1.1",
      "@auth/core": {
        "cookie": "^0.7.2"
      }
    }
  }
}
