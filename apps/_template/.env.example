# Base de datos — apuntar a la DB del cliente en el cluster compartido
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/NOMBRE_CLIENTE_db

# Auth
NEXTAUTH_URL=https://DOMINIO_CLIENTE.com
NEXTAUTH_SECRET=GENERAR_CON_openssl_rand_-base64_32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary — misma cuenta, carpeta separada por cliente
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=NOMBRE_CLIENTE

# Mercado Pago — credenciales propias del cliente
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=
FROM_EMAIL=NOMBRE_CLIENTE <no-reply@DOMINIO_CLIENTE.com>

# Identidad del ecommerce
NEXT_PUBLIC_STORE_NAME=Nombre del Cliente
NEXT_PUBLIC_URL=https://DOMINIO_CLIENTE.com
NEXT_PUBLIC_CLIENT_SLUG=nombre-cliente

# Datos de transferencia bancaria (opcional)
TRANSFER_ALIAS=
TRANSFER_CVU=
