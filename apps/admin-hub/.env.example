# apps/admin-hub — variables de entorno para desarrollo local
# Copiar a .env.local y completar. NUNCA commitear .env.local.

# URI del cluster Atlas SIN nombre de base — admin-hub accede a todas las DBs
MONGODB_CLUSTER_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Bearer token de las rutas /api y password del Basic auth de las páginas
# en producción (en dev las páginas no exigen auth).
# Generar con: openssl rand -base64 32
ADMIN_HUB_SECRET=

# Slugs de los tenants registrados, separados por coma
PLATFORM_CLIENTS=bitm-cel,kameleba,compumobile

# URL pública del admin-hub (self-fetch del dashboard; se inlinea en build)
NEXT_PUBLIC_ADMIN_URL=http://localhost:3100

# Panel de salud — opcional: sin la key el dashboard muestra "Sin configurar"
UPTIMEROBOT_API_KEY=
