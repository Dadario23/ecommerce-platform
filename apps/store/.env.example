# apps/store — variables de entorno para desarrollo local
# Copiar a .env.local y completar. Los valores reales los provee el operador
# de la plataforma. NUNCA commitear .env.local.

# Tenant activo en dev (bitm-cel | kameleba | compumobile).
# Reiniciar el servidor al cambiarlo — el middleware no lo recarga en caliente.
# En producción no se usa: el tenant se resuelve por TENANT_DOMAINS
# ("dominio.com:slug,..." — solo en las env vars de Vercel).
TENANT_SLUG=bitm-cel

# URI del cluster Atlas SIN nombre de base (el slug del tenant define la DB)
MONGODB_CLUSTER_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority

# NextAuth — generar el secreto con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth de Google (Google Cloud Console → credenciales OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (imágenes de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (emails transaccionales); FROM_EMAIL es el remitente fallback
# cuando el Setting del tenant no define fromEmail
RESEND_API_KEY=
FROM_EMAIL=

# Mercado Pago — fallbacks: en producción las credenciales viven en el
# documento Setting de cada tenant (ver CLAUDE.md). Para dev alcanza un
# token de PRUEBA de una cuenta de sandbox.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Datos de cobro por transferencia (fallback del Setting del tenant)
MP_ALIAS=
MP_CVU=

# Público
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=
